  </xs:attributeGroup>
  <xs:attributeGroup name="tei_ansatt.datable.custom.attribute.from-custom">
    <xs:attribute name="from-custom">
      <xs:annotation>
        <xs:documentation>indicates the starting point of the period in some custom standard form.</xs:documentation>
      </xs:annotation>
      <xs:simpleType>
        <xs:restriction>
          <xs:simpleType>
            <xs:list>
              <xs:simpleType>
                <xs:restriction base="xs:token">
