        </xs:choice>
      </xs:choice>
      <xs:attributeGroup ref="tei:tei_ansatt.global.attributes"/>
      <xs:attributeGroup ref="tei:tei_ansatt.editLike.attributes"/>
      <xs:attributeGroup ref="tei:tei_ansatt.sortable.attributes"/>
      <xs:attribute name="role">
        <xs:annotation>
          <xs:documentation>specifies a primary role or classification for the persona.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction>
            <xs:simpleType>
              <xs:list>
                <xs:simpleType>
                  <xs:restriction base="xs:token">
