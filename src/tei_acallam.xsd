      </xs:attribute>
      <xs:attribute name="sex">
        <xs:annotation>
          <xs:documentation>specifies the sex of the participant group.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction>
            <xs:simpleType>
              <xs:list>
                <xs:simpleType>
                  <xs:restriction base="xs:token">
                    <xs:pattern value="[^\p{C}\p{Z}]+"/>
                  </xs:restriction>
                </xs:simpleType>
              </xs:list>
            </xs:simpleType>
            <xs:minLength value="1"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="gender">
        <xs:annotation>
          <xs:documentation>specifies the gender of the participant group.</xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction>
            <xs:simpleType>
              <xs:list>
                <xs:simpleType>
                  <xs:restriction base="xs:token">
                    <xs:pattern value="[^\p{C}\p{Z}]+"/>
                  </xs:restriction>
