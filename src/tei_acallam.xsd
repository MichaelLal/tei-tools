  <xs:attributeGroup name="tei_ansatt.datable.custom.attribute.to-custom">
    <xs:attribute name="to-custom">
      <xs:annotation>
        <xs:documentation>indicates the ending point of the period in some custom standard form.</xs:documentation>
      </xs:annotation>
      <xs:simpleType>
        <xs:restriction>
          <xs:simpleType>
