      </xs:annotation>
      <xs:simpleType>
        <xs:union memberTypes="xs:date xs:gYear xs:gMonth xs:gDay xs:gYearMonth xs:gMonthDay xs:time xs:dateTime">
          <xs:simpleType>
            <xs:restriction base="xs:token">
              <xs:pattern value="[0-9.,DHMPRSTWYZ/:+\-]+"/>
