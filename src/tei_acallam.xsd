  <xs:element name="personGrp">
    <xs:annotation>
      <xs:documentation>(personal group) describes a group of individuals treated as a single person for analytic purposes. [16.2.2. The Participant Description]</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:choice>
        <xs:group maxOccurs="unbounded" ref="tei:tei_ansmodel.pLike"/>
        <xs:choice minOccurs="0" maxOccurs="unbounded">
          <xs:group ref="tei:tei_ansmodel.personPart"/>
          <xs:group ref="tei:tei_ansmodel.global"/>
        </xs:choice>
      </xs:choice>
      <xs:attributeGroup ref="tei:tei_ansatt.global.attributes"/>
      <xs:attributeGroup ref="tei:tei_ansatt.sortable.attributes"/>
      <xs:attribute name="role">
