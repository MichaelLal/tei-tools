  </xs:element>
  <xs:element name="persName">
    <xs:annotation>
      <xs:documentation>(personal name) contains a proper noun or proper-noun phrase referring to a person, possibly including one or more of the person's forenames, surnames, honorifics, added names, etc. [14.2.1. Personal Names]</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="tei:tei_ansmacro.phraseSeq">
          <xs:attributeGroup ref="tei:tei_ansatt.global.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.cmc.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.datable.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.editLike.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.personal.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.typed.attributes"/>
        </xs:extension>
      </xs:complexContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="surname">
    <xs:annotation>
      <xs:documentation>(surname) contains a family (inherited) name, as opposed to a given, baptismal, or nick name. [14.2.1. Personal Names]</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:complexContent>
        <xs:extension base="tei:tei_ansmacro.phraseSeq">
          <xs:attributeGroup ref="tei:tei_ansatt.global.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.cmc.attributes"/>
          <xs:attributeGroup ref="tei:tei_ansatt.personal.attributes"/>
